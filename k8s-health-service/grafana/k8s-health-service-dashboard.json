{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Service Ready",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "app_ready", "legendFormat": "ready"}]
    },
    {
      "type": "stat",
      "title": "Requests/sec",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(app_http_requests_total[5m]))", "legendFormat": "rps"}]
    },
    {
      "type": "stat",
      "title": "5xx Rate",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(app_http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "5xx"}]
    },
    {
      "type": "stat",
      "title": "Memory (bytes)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "app_process_resident_memory_bytes", "legendFormat": "memory"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}]
    },
    {
      "type": "timeseries",
      "title": "Dependency Latency (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "app_dependency_latency_ms", "legendFormat": "{{dependency}} {{type}}"}]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "sum(rate(app_http_requests_total[5m])) by (status_code)", "legendFormat": "{{status_code}}"}]
    },
    {
      "type": "timeseries",
      "title": "Dependency Status",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "app_dependency_status", "legendFormat": "{{dependency}} {{type}}"}]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["kubernetes", "health", "observability"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "k8s-health-service",
  "version": 1
}
